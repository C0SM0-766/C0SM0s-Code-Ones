            return btn;
        };
        prevButton = createControl("prevButton", "«");
        playButton = createControl("playButton", "►");
        nextButton = createControl("nextButton", "»");
        speedButton = createControl("speedButton", "1.0x");
        
        controlsContainer.appendChild(prevButton);

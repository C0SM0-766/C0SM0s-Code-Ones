        const playerDiv = document.createElement("div");
        playerDiv.id = YOUTUBE_PLAYER_DIV_ID;

        mainContentPanel.appendChild(coverPanel);
        mainContentPanel.appendChild(controlInfoPanel);
        mainContentPanel.appendChild(queuePanel);

        container.appendChild(mainContentPanel);
        container.appendChild(playerDiv);
        playerFragment.appendChild(container);
        return playerFragment;
    }


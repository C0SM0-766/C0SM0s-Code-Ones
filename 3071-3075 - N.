    </div>
    <progress id="progress-bar" value="0" max="100"></progress>
    <div id="volume-container">
      <span>🔊</span>
      <input id="volume-slider" type="range" min="0" max="9" step="1" value="9">
    </div>
  `;

  document.getElementById("game_window").insertAdjacentElement("afterend", player);

  const audio = document.createElement("audio");
  audio.id = "audio";
  document.body.appendChild(audio);

  let playPauseButton = player.querySelector("#playPauseButton");
  let nextButton = player.querySelector("#nextButton");
  let prevButton = player.querySelector("#prevButton");
  let volumeSlider = player.querySelector("#volume-slider");
  let progressBar = player.querySelector("#progress-bar");

  function loadSong() {
    const song = playlist.getCurrentSong();
    updateUI(playlist);
    audio.src = song.audioLink;
    audio.play();
    playPauseButton.textContent = "❚❚";
  }

  playPauseButton.addEventListener("click", () => {
    if (audio.paused) {
      audio.play();
      playPauseButton.textContent = "❚❚";
    } else {
      audio.pause();
      playPauseButton.textContent = "▶";
    }
  });
  nextButton.addEventListener("click", () => { playlist.playNext(); loadSong(); });
  prevButton.addEventListener("click", () => { playlist.playPrevious(); loadSong(); });
  volumeSlider.addEventListener("input", () => { audio.volume = volumeSlider.value / 9; });
  audio.addEventListener("timeupdate", () => {
    progressBar.value = (audio.currentTime / audio.duration) * 100 || 0;
  });
  audio.addEventListener("ended", () => { playlist.playNext(); loadSong(); });

  loadSong();
}


// Function to update the song name display based on the current track
function updateSongNameDisplay() {
  let selectedTrackIndex = Number(document.querySelector('input[name="trackSelector"]:checked').value);
  let currentSongName = soundtracks[e.selectedSoundtrack].tracklist[selectedTrackIndex].name;

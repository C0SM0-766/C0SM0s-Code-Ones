// Function to set up the music player UI and event handlers
function newMusicPlayer() {
  trackSel = document.createElement("div");
  trackSel.id = "trackSelParent";

  let z = `<div id='trackSel' style="overflow-x: hidden;height:200px; width:400px;background-color:#fff;float:right;display:none;">`;
  z += `<b><select id='selectSoundtrack'><option value='` + soundtracks[e.selectedSoundtrack].name + `'>` + soundtracks[e.selectedSoundtrack].name + "</option>";
  for (i in soundtracks) {
    if (soundtracks[e.selectedSoundtrack] != soundtracks[i]) {
      z += `<option value='` + soundtracks[i].name + `'>` + soundtracks[i].name + `</option>`;
    }
  }
  z += `</select></b><br><br>`;

  for (i in soundtracks[e.selectedSoundtrack].tracklist) {
    let a = soundtracks[e.selectedSoundtrack].tracklist[i];
    let b = `<label><input class="trackSelector" type="radio" name="trackSelector" value="` + i + `">` + a.name + `</label><br>`;
    z += b;
  }
  z += "</div><br><br>";
  trackSel.innerHTML = z;

  musicBox.appendChild(trackSel);

  // Check the first track by default
  Array.from(document.getElementById("trackSel").children).filter(f => f.tagName == "LABEL").map(f => f.children[0])[0].checked = true;

  // Event listener for soundtrack selection change
  soundtrackSelector = document.getElementById("selectSoundtrack");
  soundtrackSelector.onchange = function () {
    for (i in soundtracks) {
      if (soundtracks[i].name == soundtrackSelector.value) {
        e.selectedSoundtrack = i;
        break;
      }
    }
    document.getElementById("trackSelParent").remove();
    newMusicPlayer();
  };

  // Event listener for track selection change
  var matches = document.querySelectorAll('.trackSelector');
  for (let match of matches) {
    match.onchange = function () {
      let audio = $("#campaigntrailmusic")[0];
      audio.src = soundtracks[e.selectedSoundtrack].tracklist[this.value].url;
      audio.currentTime = 0;
      audio.play(); // Automatically play the new track
      updateSongNameDisplay(); // Update song name display when track is changed
    };
  }

  // Initialize the audio element
  let audio = $("#campaigntrailmusic")[0];
  audio.loop = false;
  audio.src = soundtracks[e.selectedSoundtrack].tracklist[0].url;

  // Event listener for when the current track ends
  audio.onended = function () {
    let selected = Number(document.querySelector('input[name="trackSelector"]:checked').value);
    let newSel = clamp(selected + 1, soundtracks[e.selectedSoundtrack].tracklist.length - 1, 0);
    
    // Set the new track's value in the audio element directly
    audio.src = soundtracks[e.selectedSoundtrack].tracklist[newSel].url;
    audio.currentTime = 0;
    audio.play(); // Start playing the new track

    // Update the radio button selection visually
    let buttons = Array.from(document.getElementById("trackSel").children).filter(f => f.tagName === "LABEL").map(f => f.children[0]);
    buttons[newSel].checked = true; // Set the new radio button as checked

    // Call updateSongNameDisplay to update the title display
    updateSongNameDisplay();
  };

  // Set the initial song name display
  updateSongNameDisplay();

  // Generate play/pause button and time tracker
  generateTime();
}

// Function to set up the play/pause button and time display
generateTime = () => {
  // Get the audio element
  var audio = document.getElementById("campaigntrailmusic");

  // Set initial volume
  audio.volume = 1;

  // Create and style the timeTracker container
  let timeTracker = document.createElement("div");
  timeTracker.style = `
    text-align: center;
    border: none;
    height: 0px;
    width: 450px;
    background-color: transparent;
    float: right;
    padding: 10px;
    display: flex;
    justify-content: flex-end; /* Aligns buttons to the right */
    align-items: center;
    gap: 10px;
    z-index: 9999;
  `;
  if ($("#trackSelParent")[0]) {
    $("#trackSelParent")[0].prepend(timeTracker);
  } else {
    document.body.appendChild(timeTracker);
  }

  // Create play/pause button
  let pausePlay = document.createElement("button");
  pausePlay.id = "play-pause-button";
  pausePlay.innerHTML = "<b>❚❚</b>";
  pausePlay.style = `
    width: 75px;
    height: 40px;
    border-radius: 5px;
    border: 2px solid #6d7ca1;
    background-color: #6d7ca1;
    color: #fff;
    cursor: pointer;
    z-index: 99999;
  `;
  pausePlay.addEventListener("click", (event) => {
    event.preventDefault();
    if (audio.paused) {
      audio.play();
      event.target.innerHTML = "<b>❚❚</b>";
      updateSongNameDisplay(); // Update the song name when playing
    } else {
      audio.pause();
      event.target.innerHTML = "<b>▶</b>";
      createSongNameDisplay().innerHTML = "Playback paused"; // Update text when paused
    }
  });

  // Create "Previous" and "Next" buttons (similar to original code)
  let prevButton = document.createElement("button");
  prevButton.id = "prev-button";
  prevButton.innerHTML = "<b>⇦</b>";
  prevButton.style = pausePlay.style;
  prevButton.addEventListener("click", () => {
    let selected = Number(document.querySelector('input[name="trackSelector"]:checked').value);
    let newSel = clamp(selected - 1, soundtracks[e.selectedSoundtrack].tracklist.length - 1, 0);
    let buttons = Array.from(document.getElementById("trackSel").children).filter(f => f.tagName === "LABEL").map(f => f.children[0]);
    buttons[newSel].checked = true;
    audio.src = soundtracks[e.selectedSoundtrack].tracklist[newSel].url;
    audio.currentTime = 0;
    audio.play();
    updateSongNameDisplay();
  });

  let nextButton = document.createElement("button");
  nextButton.id = "next-button";
  nextButton.innerHTML = "<b>⇨</b>";
  nextButton.style = pausePlay.style;
  nextButton.addEventListener("click", () => {
    let selected = Number(document.querySelector('input[name="trackSelector"]:checked').value);
    let newSel = clamp(selected + 1, soundtracks[e.selectedSoundtrack].tracklist.length - 1, 0);
    let buttons = Array.from(document.getElementById("trackSel").children).filter(f => f.tagName === "LABEL").map(f => f.children[0]);
    buttons[newSel].checked = true;
    audio.src = soundtracks[e.selectedSoundtrack].tracklist[newSel].url;
    audio.currentTime = 0;
    audio.play();
    updateSongNameDisplay();
  });

  // Append buttons to timeTracker
  timeTracker.appendChild(prevButton);
  timeTracker.appendChild(pausePlay);
  timeTracker.appendChild(nextButton);

  // Create Volume Slider
  let volumeContainer = document.createElement("div");
  volumeContainer.style.marginTop = "0px"; // Margin to separate from buttons

  let volumeLabel = document.createElement("label");
  volumeLabel.htmlFor = "volume-slider";
  volumeLabel.style.color = "#1a213a";

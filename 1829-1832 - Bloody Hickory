function addPlaylistSelector(playlists) {
    const selectorContainer = document.createElement("div");
    selectorContainer.id = "playlistSelectorContainer";
    selectorContainer.innerHTML = `
        <select id="playlistSelector">
            <option value="playlist1">Modern Soundtrack</option>
            <option value="playlist2">Classical Soundtrack</option>
        </select>
    `;

    // You can move this selector anywhere by editing these coordinates:
    selectorContainer.style.position = "absolute";
    selectorContainer.style.left = "815px";  // ← horizontal position
    selectorContainer.style.top = "1020px";   // ← vertical position
    selectorContainer.style.zIndex = "9999";

    document.body.appendChild(selectorContainer);

    const selector = selectorContainer.querySelector("#playlistSelector");
    selector.addEventListener("change", (e) => {
        const selected = e.target.value;
        if (selected === "playlist1") changePlaylist(playlists.playlist1);
        else if (selected === "playlist2") changePlaylist(playlists.playlist2);
    });
}

  const setupKeyListener = () => {
    document.addEventListener('keydown', event => {
      if (event.key === 'Escape') {
        hideCredits();
      }
    });
  };

  const init = () => {
    injectCSS();
    setupKeyListener();

    window.showCredits = showCredits;
  };

  init();
})();

